generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  id            String         @id @default(cuid())
  fullName      String
  cnic          String         @unique
  dateOfBirth   DateTime
  gender        String
  nationality   String         @default("Pakistan")
  mobileNumber  String         @unique
  landline      String?
  email         String         @unique
  password      String
  province      String
  district      String
  tehsil        String?
  address       String
  profilePicture String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  complaints    Complaint[]
  suggestions   Suggestion[]
  eServices     EService[]
  notifications Notification[]

  @@map("citizens")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("admins")
}

model Complaint {
  id               String   @id @default(cuid())
  citizenId        String
  citizen          Citizen  @relation(fields: [citizenId], references: [id])
  category         String
  subCategory      String?
  complaintType    String   @default("Personal Grievance")
  subject          String
  description      String
  province         String?
  district         String?
  tehsil           String?
  complaintAddress String?
  hideIdentity     Boolean  @default(false)
  attachmentUrl    String?
  status           String   @default("Pending")
  adminNote        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("complaints")
}

model Suggestion {
  id                String   @id @default(cuid())
  citizenId         String
  citizen           Citizen  @relation(fields: [citizenId], references: [id])
  category          String
  department        String?
  suggestionType    String   @default("Personal")
  subject           String
  description       String
  province          String?
  district          String?
  tehsil            String?
  suggestionAddress String?
  hideIdentity      Boolean  @default(false)
  attachmentUrl     String?
  status            String   @default("Pending")
  adminNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("suggestions")
}

model EService {
  id            String   @id @default(cuid())
  citizenId     String
  citizen       Citizen  @relation(fields: [citizenId], references: [id])
  serviceType   String
  subject       String
  description   String
  attachmentUrl String?
  status        String   @default("Pending")
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("e_services")
}

model Notification {
  id        String   @id @default(cuid())
  citizenId String
  citizen   Citizen  @relation(fields: [citizenId], references: [id])
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}