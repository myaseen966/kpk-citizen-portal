# Local .terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files (contain sensitive data - use a remote backend instead)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files that may contain secrets
*.tfvars
*.auto.tfvars
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
